# ============================================================================
# CONFIGURACIÓN DEL SISTEMA
# ============================================================================

# Aplicación
APP_NAME="Sistema Óptica"
APP_VERSION="1.0.0"
DEBUG=True
ENVIRONMENT=development

# Secret Key (¡CAMBIAR EN PRODUCCIÓN!)
SECRET_KEY=tu_secret_key_super_seguro_cambiar_en_produccion_2026
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================================================
# BASE DE DATOS
# ============================================================================

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://optica_user:optica_password_2026@localhost:5432/optica_system
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# MongoDB
MONGODB_URL=mongodb://optica_admin:optica_mongo_2026@localhost:27017/optica_clinico?authSource=admin
MONGODB_DB_NAME=optica_clinico

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# ============================================================================
# CORS
# ============================================================================

CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]

# ============================================================================
# EMAIL (SMTP)
# ============================================================================

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_email@gmail.com
SMTP_PASSWORD=tu_password
SMTP_FROM_EMAIL=noreply@optica.com
SMTP_FROM_NAME="Sistema Óptica"

# ============================================================================
# CFDI (Facturación Electrónica)
# ============================================================================

CFDI_API_URL=https://api.facturacion.com
CFDI_API_KEY=tu_api_key
CFDI_CERTIFICATE_PATH=/certs/CSD.cer
CFDI_KEY_PATH=/certs/CSD.key
CFDI_PASSWORD_CERT=tu_password_cert

# ============================================================================
# ALMACENAMIENTO
# ============================================================================

UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10485760  # 10MB

# ============================================================================
# LOGGING
# ============================================================================

LOG_LEVEL=INFO
LOG_FILE=./logs/app.log